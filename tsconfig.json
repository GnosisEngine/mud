{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "lib": ["ES2020"],
    "module": "node16",
    "moduleResolution": "node16",
    "strictPropertyInitialization": false,
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": ["types/**/*.ts", "types/**/*.d.ts"]
}