{
  "compilerOptions": {
    "checkJs": true,
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "moduleResolution": "node",
    "target": "ES2020"
  },
  "exclude": ["node_modules", "data", "log"]
}