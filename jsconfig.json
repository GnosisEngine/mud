{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "module": "commonjs",
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitAny": false,
    "noImplicitThis": true,
    "moduleResolution": "node",
    "target": "ES2020",
    "baseUrl": ".",
    "typeRoots": ["./types", "./node_modules/@types"],
    "paths": {
      "ranvier":  ["./types/ranvier/index.d.ts"],
      "types":    ["./types/index.d.ts"],
      "types/*":  ["./types/*.d.ts"]
    }
  },
  "exclude": ["node_modules", "data", "log"]
}