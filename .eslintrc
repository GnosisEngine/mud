{
    "env": {
        "node": true,
        "es2020": true
    },
    "parserOptions": {
        "ecmaVersion": 2020
    },
    "rules": {
        "strict": [
            "error",
            "global"
        ],
        "no-var": "error",
        "prefer-const": "warn",
        "no-unused-vars": [
            "warn",
            {
                "argsIgnorePattern": "^_"
            }
        ],
        "no-undef": "error",
        "indent": [
            "error",
            2,
            {
                "SwitchCase": 1
            }
        ],
        "quotes": [
            "error",
            "single",
            {
                "avoidEscape": true
            }
        ],
        "semi": [
            "error",
            "always"
        ],
        "comma-dangle": [
            "error",
            "only-multiline"
        ],
        "eol-last": [
            "error",
            "always"
        ],
        "no-trailing-spaces": "error",
        "space-before-function-paren": [
            "error",
            "never"
        ],
        "keyword-spacing": [
            "error",
            {
                "before": true,
                "after": true
            }
        ],
        "space-infix-ops": "error",
        "object-curly-spacing": [
            "error",
            "always"
        ],
        "array-bracket-spacing": [
            "error",
            "never"
        ],
        "no-console": "off",
        "no-process-exit": "off"
    }
}