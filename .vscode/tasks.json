{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "typecheck:watch",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json --watch --noEmit",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": "$tsc-watch",
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json --noEmit",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$tsc"
    }
  ]
}